{
    "manifest_version": 3,
    "name": "Grafana SQL DataLink",
    "version": "1.0",
    "description": "将页面上15~20位数字hash替换为对应的原始SQL",
    "permissions": ["scripting"],
    "host_permissions": [
        "https://replace_me/*",
        "https://replace_me/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["http://example.com/specific_page.html*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "128": "icon.png"
    }
}
